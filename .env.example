# ─── Required ────────────────────────────────────────────────────────────────
# MySQL connection string — use your cPanel database credentials
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME

# Random secret for signing user sessions — use a long random string (64+ chars)
SESSION_SECRET=replace-with-a-very-long-random-secret-string-here

# Always "production" on cPanel
NODE_ENV=production

# Port — cPanel usually sets this automatically; set to 3000 if not provided
PORT=3000

# ─── Email / SMTP (optional — for order emails, OTP, etc.) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Razorpay (optional — only if using Razorpay payment gateway) ─────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ─── Busan API (optional — only if using Busan top-up integration) ────────────
BUSAN_API_TOKEN=your-busan-api-token
BUSAN_API_URL=https://1gamestopup.com/api/v1

# ─── Smile.one API (optional — only if using Smile.one integration) ───────────
SMILEONE_UID=your-uid
SMILEONE_EMAIL=your-smileone-email
SMILEONE_API_KEY=your-api-key
