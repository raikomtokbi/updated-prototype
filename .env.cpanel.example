# ============================================================
# Nexcoin — cPanel Environment Variables
# Set these in cPanel → Node.js App → Environment Variables
# ============================================================

# MySQL database connection (cPanel format)
DATABASE_URL=mysql://cpaneluser_dbuser:your_password@localhost:3306/cpaneluser_dbname

# Required: generate a strong random secret (e.g. openssl rand -hex 32)
SESSION_SECRET=replace_with_a_long_random_string

# Node environment — MUST be production on cPanel
NODE_ENV=production

# Port — cPanel usually sets this automatically; leave as 5000 if unsure
PORT=5000

# Optional: SMTP for transactional email
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=Nexcoin
